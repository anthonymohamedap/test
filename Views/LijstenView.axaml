<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:QuadroApp.Converters"
    x:Class="QuadroApp.Views.LijstenView"
    x:DataType="vm:LijstenViewModel"
    d:DataContext="{d:DesignInstance vm:LijstenViewModel, IsDesignTimeCreatable=True}"
    Background="#F5F5F5">

    <UserControl.Resources>
        <conv:BoolToThicknessConverter x:Key="BoolToThicknessSlide"
                                       WhenTrue="0"
                                       WhenFalse="0,0,-540,0"/>
        <conv:BoolToThicknessConverter x:Key="BoolToMainShift"
                                       WhenTrue="0,0,540,0"
                                       WhenFalse="0"/>
        <conv:BoolToDoubleConverter x:Key="BoolToOpacity"
                                    WhenTrue="1"
                                    WhenFalse="0"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <Border Grid.ColumnSpan="2" Background="#444A50" Height="70">
            <DockPanel LastChildFill="False" Margin="20,0">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <Ellipse Width="35" Height="35" Fill="#F5C242"/>
                    <TextBlock Text="QUADRO"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="20"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="LijstenBeheer"
                               Foreground="#CCC"
                               FontSize="13"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="Terug"
                        Command="{Binding GaTerugCommand}"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,10,10,0"
                        Background="#F5C242"
                        Foreground="#222"
                        FontWeight="Bold"
                        CornerRadius="8"
                        Padding="10,5"
                        Width="100"
                        Height="32"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">

            <StackPanel Spacing="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        MaxWidth="850">

                <StackPanel.Transitions>
                    <Transitions>
                        <ThicknessTransition Property="Margin" Duration="0:0:0.25"/>
                    </Transitions>
                </StackPanel.Transitions>
                <StackPanel.Margin>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToMainShift}"/>
                </StackPanel.Margin>

                <TextBlock Text="TypeLijsten"
                           FontSize="22"
                           FontWeight="Bold"/>

                <Grid ColumnDefinitions="Auto,Auto"
                      ColumnSpacing="10">

                    <TextBox Grid.Column="0"
                             Width="280"
                             Height="34"
                             Watermark="Zoek op artikelnummer of leverancier..."
                             Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">

                        <Button Content="🗑️ Verwijderen" Command="{Binding DeleteCommand}" Classes="MainBtn"/>
                        <Button Content="💾 Opslaan" Command="{Binding SaveCommand}" Classes="MainBtn"/>
                        <Button Content="🔄 Ververs" Command="{Binding RefreshCommand}" Classes="MainBtn"/>
                        <Button Content="📥 Excel-import" Command="{Binding ImportExcelCommand}" Classes="MainBtn"/>
                        <Button Content="🧩 Bulk bijwerken" Command="{Binding BulkPrijsUpdateCommand}" Classes="MainBtn"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Content="Vorige"
                            Command="{Binding PrevPageCommand}"
                            Classes="MainBtn"/>
                    <Button Content="Volgende"
                            Command="{Binding NextPageCommand}"
                            Classes="MainBtn"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="White"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0">

                        <StackPanel>
                            <Border Background="#F3F4F6"
                                    Padding="10,6"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="0,0,0,1">

                                <Grid ColumnDefinitions="1.2*,1.3*,0.8*,0.9*,0.8*,2.2*"
                                      ColumnSpacing="12">

                                    <TextBlock Text="Artikelnummer"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="1"
                                               Text="Leverancier"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="2"
                                               Text="Breedte"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="3"
                                               Text="Voorraad"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="4"
                                               Text="Minimum"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="5"
                                               Text="Opmerking"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </Border>

                            <ListBox x:Name="LijstenList"
                                     ItemsSource="{Binding PagedLijsten}"
                                     SelectedItem="{Binding GeselecteerdeLijst, Mode=TwoWay}"
                                     SelectionMode="Multiple"
                                     SelectionChanged="LijstenList_SelectionChanged"
                                     BorderThickness="0"
                                     Background="Transparent">

                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:TypeLijst">

                                        <Border Padding="10,6">
                                            <Grid ColumnDefinitions="1.2*,1.3*,0.8*,0.9*,0.8*,2.2*"
                                                  ColumnSpacing="12">

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Artikelnummer}"
                                                           FontWeight="Bold"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Leverancier.Naam}"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding BreedteCm}"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding VoorraadMeter, StringFormat='{}{0:0.##} m'}"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding MinimumVoorraad, StringFormat='{}{0:0.##} m'}"/>

                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding Opmerking}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>

                        </StackPanel>

                    </Border>
                </ScrollViewer>

                <TextBlock Text="{Binding AantalLijsten, StringFormat='Aantal geladen lijsten: {0}'}"
                           Foreground="#666"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Width="520"
                    Padding="24"
                    Background="White"
                    CornerRadius="10"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsHitTestVisible="{Binding IsDetailOpen}">

                <Border.Transitions>
                    <Transitions>
                        <ThicknessTransition Property="Margin" Duration="0:0:0.2"/>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    </Transitions>
                </Border.Transitions>

                <Border.Margin>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToThicknessSlide}"/>
                </Border.Margin>
                <Border.Opacity>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToOpacity}"/>
                </Border.Opacity>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Lijstdetails"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#222"/>

                        <Border Background="#FFF8E1"
                                CornerRadius="8"
                                Padding="10"
                                IsVisible="{Binding !IsDetailOpen}">
                            <TextBlock Text="Selecteer links een lijst om details te zien."
                                       Foreground="#333"/>
                        </Border>

                        <StackPanel x:DataType="vm:LijstenViewModel"
                                    Spacing="18"
                                    IsVisible="{Binding IsDetailOpen}">

                            <Grid ColumnDefinitions="2*,3*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="7"
                                  ColumnSpacing="15">

                                <TextBlock Text="Artikelnummer" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.Artikelnummer, Mode=TwoWay}" Grid.Row="0" Grid.Column="1"/>

                                <TextBlock Text="Levcode" Grid.Row="1" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.Levcode, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>

                                <TextBlock Text="Leverancier" Grid.Row="2" Grid.Column="0" FontWeight="Bold"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                    <Border Background="#EEF2FF"
                                            CornerRadius="6"
                                            Padding="6">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#1E40AF"
                                                   Text="{Binding SelectedLeverancier.Naam, TargetNullValue='Geen leverancier geselecteerd'}"/>
                                    </Border>

                                    <TextBox Watermark="Zoek leverancier..."
                                             Text="{Binding LeverancierZoekterm, UpdateSourceTrigger=PropertyChanged}"/>

                                    <ComboBox ItemsSource="{Binding GefilterdeLeveranciers}"
                                              SelectedItem="{Binding SelectedLeverancier, Mode=TwoWay}"
                                              MaxDropDownHeight="250">

                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:Leverancier">
                                                <TextBlock>
                                                    <Run Text="{Binding Naam}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>

                                    </ComboBox>
                                </StackPanel>

                                <TextBlock Text="Breedte" Grid.Row="3" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.BreedteCm, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>

                                <TextBlock Text="Soort" Grid.Row="4" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.Soort, Mode=TwoWay}" Grid.Row="4" Grid.Column="1"/>

                                <TextBlock Text="Voorraad" Grid.Row="5" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.VoorraadMeter, Mode=TwoWay}" Grid.Row="5" Grid.Column="1"/>

                                <TextBlock Text="InventarisKost" Grid.Row="6" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.InventarisKost, Mode=TwoWay}" Grid.Row="6" Grid.Column="1"/>

                                <TextBlock Text="PrijsPerMeter" Grid.Row="7" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.PrijsPerMeter, Mode=TwoWay}" Grid.Row="7" Grid.Column="1"/>

                                <TextBlock Text="VasteKost" Grid.Row="8" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.VasteKost, Mode=TwoWay}" Grid.Row="8" Grid.Column="1"/>

                                <TextBlock Text="WerkMinuten" Grid.Row="9" Grid.Column="0" FontWeight="Bold"/>
                                <TextBox Foreground="Black" Text="{Binding GeselecteerdeLijst.WerkMinuten, Mode=TwoWay}" Grid.Row="9" Grid.Column="1"/>

                                <TextBlock Text="Opmerking" Grid.Row="10" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="10"
                                         Grid.Column="1"
                                         Foreground="Black"
                                         Text="{Binding GeselecteerdeLijst.Opmerking, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         MinHeight="120"/>
                            </Grid>

                            <Button Content="Opslaan wijzigingen"
                                    Command="{Binding SaveCommand}"
                                    Background="#444A50"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    FontWeight="Bold"
                                    Width="220"
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            </Border>

        </Grid>
    </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        xmlns:m="using:QuadroApp.Model.DB"
        x:Class="QuadroApp.Views.BulkLijstenWindow"
        x:DataType="vm:BulkLijstenViewModel"
        Width="1100"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Title="Bulk Lijsten"
        Background="#F5F5F5">

    <Grid RowDefinitions="Auto,*">
        <Border Background="#444A50" Height="70">
            <DockPanel Margin="20,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Ellipse Width="35" Height="35" Fill="#F5C242"/>
                    <TextBlock Text="QUADRO" Foreground="White" FontWeight="Bold" FontSize="20"/>
                    <TextBlock Text="BULK LIJSTEN" Foreground="#CCC" FontSize="13" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="Sluiten"
                        Command="{Binding SluitenCommand}"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,10,10,0"
                        Background="#F5C242"
                        Foreground="#222"
                        FontWeight="Bold"
                        CornerRadius="8"
                        Padding="10,5"
                        Width="100"
                        Height="32"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20" RowDefinitions="Auto,*" RowSpacing="12">
            <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Selecteer lijsten via filters en voer een bulkactie uit"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <Grid ColumnDefinitions="2*,1*,1*,1*" ColumnSpacing="10">
                        <TextBox Grid.Column="0"
                                 Watermark="Zoek op artikelnummer of leverancier"
                                 Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SoortOptions}"
								  Foreground="White"
                                  SelectedItem="{Binding SoortFilter, Mode=TwoWay}"/>

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding SerieOptions}"
								  Foreground="White"
                                  SelectedItem="{Binding SerieFilter, Mode=TwoWay}"/>

                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding ActionModes}"
								  Foreground="White"
                                  SelectedItem="{Binding SelectedAction, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Price input panel — only visible for BulkPrijsUpdate -->
                    <Border IsVisible="{Binding IsPrijsUpdateMode}"
                            Background="#F0F6FF"
                            BorderBrush="#93C5FD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Prijs aanpassing" FontWeight="SemiBold" FontSize="13"/>

                            <!-- Toggle absolute / percentage -->
                            <CheckBox Content="Gebruik percentage (%)"
                                      IsChecked="{Binding GebruikPercentage, Mode=TwoWay}"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

                                <!-- Absolute new price -->
                                <StackPanel Grid.Column="0"
                                            IsVisible="{Binding IsAbsolutePrijs}"
                                            Spacing="4">
                                    <TextBlock Text="Nieuwe prijs per meter (€)" FontSize="12" Foreground="#555"/>
                                    <NumericUpDown Value="{Binding NieuwePrijsPerMeter, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Increment="0.50"
                                                   FormatString="0.00"
                                                   Watermark="bv. 12.50"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <!-- Percentage change -->
                                <StackPanel Grid.Column="1"
                                            IsVisible="{Binding GebruikPercentage}"
                                            Spacing="4">
                                    <TextBlock Text="Wijziging (%)" FontSize="12" Foreground="#555"/>
                                    <NumericUpDown Value="{Binding PrijsWijzigingPct, Mode=TwoWay}"
                                                   Increment="1"
                                                   FormatString="0.00"
                                                   Watermark="bv. 5 of -3"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>

                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding SelectedCount, StringFormat='Geselecteerd: {0}'}"
                               Foreground="#666"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Background="#F3F4F6" Padding="10,6" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="1.4*,1.4*,0.8*,0.9*,0.8*,0.8*" ColumnSpacing="12">
                            <TextBlock Text="Artikelnummer" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Leverancier" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Soort" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Serie" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Voorraad" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Prijs/m" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="BulkLijstenList"
                             ItemsSource="{Binding FilteredLijsten}"
                             SelectionMode="Multiple"
                             SelectionChanged="BulkLijstenList_SelectionChanged"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:TypeLijst">
                                <Border Padding="10,6">
                                    <Grid ColumnDefinitions="1.4*,1.4*,0.8*,0.9*,0.8*,0.8*" ColumnSpacing="12">
                                        <TextBlock Text="{Binding Artikelnummer}" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Leverancier.Naam}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Soort}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Serie}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding VoorraadMeter, StringFormat='{}{0:0.##}'}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding PrijsPerMeter, StringFormat='{}{0:0.00}'}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="12">
                        <TextBlock Text="{Binding SelectedCount, StringFormat='({0} geselecteerd)'}"
                                   VerticalAlignment="Center"
                                   Foreground="#666"
                                   Margin="0,0,8,0"/>
                        <Button Content="Uitvoeren"
                                Command="{Binding ExecuteActionCommand}"
                                Classes="MainBtn"/>
                        <Button Content="Annuleren"
                                Command="{Binding SluitenCommand}"
                                Classes="MainBtn"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>




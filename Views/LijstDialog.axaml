<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:QuadroApp.Model.DB"
        x:Class="QuadroApp.Views.LijstDialog"
        x:DataType="m:TypeLijst"
        Width="520"
        Height="700"
        Title="🧾 Lijst bewerken"
        Background="#F5F5F5"
        WindowStartupLocation="CenterOwner">

	<Border CornerRadius="10" BorderBrush="#DDD" BorderThickness="1" Margin="15" Padding="20" Background="White">
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel Spacing="14">
				<TextBlock Text="🧾 Lijstgegevens" FontSize="22" FontWeight="Bold" Foreground="#222" Margin="0,0,0,10"/>

				<TextBox Text="{Binding Artikelnummer}" Watermark="Artikelnummer"/>
				<TextBox Text="{Binding Levcode}" Watermark="Levcode"/>
				<TextBox Text="{Binding Leverancier.Naam}" Watermark="Leverancier" IsReadOnly="True"/>
				<TextBox Text="{Binding Soort}" Watermark="Soort"/>
				<TextBox Text="{Binding Serie}" Watermark="Serie"/>
				<NumericUpDown Value="{Binding BreedteCm}" Minimum="0" Maximum="100" Increment="1"/>
				<NumericUpDown Value="{Binding VoorraadMeter}" Increment="0.5"/>
				<NumericUpDown Value="{Binding InventarisKost}" Increment="0.1"/>
				<NumericUpDown Value="{Binding PrijsPerMeter}" Increment="0.1"/>
				<NumericUpDown Value="{Binding VasteKost}" Increment="0.5"/>
				<NumericUpDown Value="{Binding WerkMinuten}" Increment="1"/>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
					<Button Content="Annuleren" Width="100" Background="#999" Foreground="White" Click="Annuleer_Click"/>
					<Button Content="Opslaan" Width="120" Background="#444A50" Foreground="White" Click="Opslaan_Click"/>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Border>
</Window>

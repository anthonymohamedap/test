<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuadroApp.ViewModels"
             xmlns:views="using:QuadroApp.Views"
             xmlns:huskui="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="QuadroApp.App">

	<Application.Styles>
		<huskui:HuskuiTheme />
	</Application.Styles>

	<Application.DataTemplates>
		<DataTemplate DataType="{x:Type vm:HomeViewModel}">
			<views:HomeView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:KlantenViewModel}">
			<views:KlantenView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:LijstenViewModel}">
			<views:LijstenView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:LeveranciersViewModel}">
			<views:LeveranciersView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:OfferteViewModel}">
			<views:OfferteView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:OffertesLijstViewModel}">
			<views:OffertesLijstView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:KlantDetailViewModel}">
			<views:KlantDetailView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:AfwerkingenViewModel}">
			<views:AfwerkingenView/>
		</DataTemplate>

		<DataTemplate DataType="vm:WerkBonLijstViewModel">
			<views:WerkBonLijstView/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type vm:FacturenViewModel}">
			<views:FacturenView/>
		</DataTemplate>
	</Application.DataTemplates>

</Application>
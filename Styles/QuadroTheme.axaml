<!-- Styles/QuadroTheme.axaml -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Global resources (colors, thickness, corner radius, etc.) -->
	<Styles.Resources>
		<!-- Colors -->
		<Color x:Key="QuadroAccentColor">#F6C43E</Color>
		<Color x:Key="QuadroHeaderColor">#3A3A3A</Color>
		<Color x:Key="QuadroTextDark">#000000</Color>
		<Color x:Key="QuadroTextLight">#000000 </Color>
		<Color x:Key="QuadroBorder">#E0E0E0</Color>
		<Color x:Key="QuadroBackground">#F8F8F8</Color>

		<!-- Misc -->
		<Thickness x:Key="QuadroPagePadding">20</Thickness>
		<CornerRadius x:Key="QuadroCorner">10</CornerRadius>
	</Styles.Resources>

	<!-- Text styles -->
	<Style Selector="TextBlock.quadro-title">
		<Setter Property="FontSize" Value="22"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{DynamicResource QuadroTextDark}"/>
	</Style>

	<Style Selector="TextBlock.quadro-subtitle">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="Foreground" Value="{DynamicResource QuadroTextLight}"/>
		<Setter Property="FontStyle" Value="Italic"/>
	</Style>

	<!-- Buttons -->
	<Style Selector="Button.quadro-accent">
		<Setter Property="Background" Value="{DynamicResource QuadroAccentColor}"/>
		<Setter Property="Foreground" Value="Black"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Padding" Value="8,4"/>
		<Setter Property="CornerRadius" Value="6"/>
	</Style>

	<Style Selector="Button.quadro-default">
		<Setter Property="Background" Value="#E0E0E0"/>
		<Setter Property="Foreground" Value="#333"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Padding" Value="8,4"/>
		<Setter Property="CornerRadius" Value="6"/>
	</Style>

	<!-- Card border -->
	<Style Selector="Border.quadro-card">
		<Setter Property="Background" Value="White"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="BorderBrush" Value="{DynamicResource QuadroBorder}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="15"/>
	</Style>
	<Style Selector="Button.IconBtn">
		<Setter Property="Width" Value="40"/>
		<Setter Property="Height" Value="40"/>
		<Setter Property="FontSize" Value="18"/>
		<Setter Property="CornerRadius" Value="6"/>
		<Setter Property="Background" Value="#444A50"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="Margin" Value="4"/>
	</Style>

	<Style Selector="Button.IconBtn:pointerover">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="Foreground" Value="#222"/>
	</Style>

	<!-- Buttons: MainBtn (globaal) -->
	<Style Selector="Button.MainBtn">
		<Setter Property="Background" Value="#444A50"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="Padding" Value="10,5"/>
	</Style>
	<Style Selector="Button.MainBtn:pointerover">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="Foreground" Value="#222"/>
	</Style>

	<!-- Button.GhostBtn (herbruikbaar, donkere achtergrond) -->
	<Style Selector="Button.GhostBtn">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="#9299AE"/>
		<Setter Property="BorderBrush" Value="#9299AE"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="12,6"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="Cursor" Value="Hand"/>
	</Style>
	<Style Selector="Button.GhostBtn:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="#252830"/>
	</Style>

	<!-- TextBlock: standaard zwart voor lichte views -->
	<Style Selector="TextBlock">
		<Setter Property="Foreground" Value="Black"/>
	</Style>

	<!-- ListBoxItem: standaard Quadro-stijl -->
	<Style Selector="ListBoxItem">
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Margin" Value="0,0,0,6"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="ListBoxItem:pointerover">
		<Setter Property="Background" Value="#FFF7DA"/>
	</Style>
	<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="TextElement.Foreground" Value="#222"/>
	</Style>
	<Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="#FFECB3"/>
	</Style>

	<!-- DataGrid: horizontale lijnen, lichte header -->
	<Style Selector="DataGrid">
		<Setter Property="GridLinesVisibility" Value="Horizontal"/>
	</Style>
	<Style Selector="DataGridColumnHeader">
		<Setter Property="Background" Value="#F3F4F6"/>
		<Setter Property="Foreground" Value="#000"/>
		<Setter Property="BorderBrush" Value="#E5E7EB"/>
	</Style>

	<!-- ScrollBar: slim design -->
	<Style Selector="ScrollBar">
		<Setter Property="Width" Value="6"/>
		<Setter Property="Opacity" Value="0.5"/>
	</Style>

	<!-- ComboBox: zwarte tekst, licht geel op hover -->
	<Style Selector="ComboBox">
		<Setter Property="Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBox /template/ ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem">
		<Setter Property="Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="#FFF8D6"/>
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="#FFF8D6"/>
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>

</Styles>

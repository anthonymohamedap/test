<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.InstellingenWindow"
        x:DataType="vm:InstellingenViewModel"
        Width="780"
        Height="560"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Title="Instellingen"
        Background="#F5F5F5">

    <Grid RowDefinitions="Auto,*">
        <Border Background="#444A50" Height="70">
            <DockPanel Margin="20,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Ellipse Width="35" Height="35" Fill="#F5C242"/>
                    <TextBlock Text="QUADRO" Foreground="White" FontWeight="Bold" FontSize="20"/>
                    <TextBlock Text="INSTELLINGEN" Foreground="#CCC" FontSize="13" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="Sluiten"
                        Click="Close_Click"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,10,10,0"
                        Background="#F5C242"
                        Foreground="#222"
                        FontWeight="Bold"
                        CornerRadius="8"
                        Padding="10,5"
                        Width="100"
                        Height="32"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="16">
                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Staaflijst Pricing" FontSize="18" FontWeight="SemiBold" Foreground ="Black"/>

                        <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="StaaflijstWinstFactor" FontWeight="Bold" Foreground ="Black"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StaaflijstWinstFactor, Mode=TwoWay}" Foreground ="Black"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="StaaflijstAfvalPercentage" FontWeight="Bold" Foreground ="Black"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StaaflijstAfvalPercentage, Mode=TwoWay}" Foreground ="Black"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Default Pricing" FontSize="18" FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DefaultWinstFactor" FontWeight="Bold" Foreground ="Black"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefaultWinstFactor, Mode=TwoWay}" Foreground ="Black"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DefaultAfvalPercentage" FontWeight="Bold" Foreground ="Black"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultAfvalPercentage, Mode=TwoWay}" Foreground ="Black"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button Content="Opslaan"
                            Command="{Binding SaveCommand}"
                            Classes="MainBtn"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
